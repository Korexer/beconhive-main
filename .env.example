VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key

# SMTP Configuration (Edge Function secrets — set via: npx supabase secrets set)
SMTP_HOST=mail.lonex.com
SMTP_PORT=465
SMTP_USER=your_smtp_email@yourdomain.com
SMTP_PASS=your_smtp_password

# Email identity
WAITLIST_FROM_EMAIL=Beconhive AI <info@beconhive.com>
WAITLIST_REPLY_TO=info@beconhive.com
PUBLIC_SITE_URL=https://www.beconhive.com
